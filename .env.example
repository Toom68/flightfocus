# Server-side environment variables for Netlify Functions
# Set these in Netlify dashboard: Site settings → Environment variables
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Jamendo free-music API client ID (read-only catalog access).
# Used by the music-list / music-stream functions to power Focus Music.
# Free signup at https://developer.jamendo.com — no redirect URL or secret needed.
JAMENDO_CLIENT_ID=
