# Copy this file to `.env` and fill in your key.
# NOTE: Vite inlines VITE_* vars into the client bundle, so this key is
# visible to anyone using the deployed app. Use a key with strict usage
# limits, and rotate it if it leaks. The journal feature degrades gracefully
# to a local template generator when no key is present.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
